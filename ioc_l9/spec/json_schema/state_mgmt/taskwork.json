{
  "$defs": {
    "Episode": {
      "description": "A discrete conversation or interaction sequence tied to a task.\nAn episode groups the messages exchanged during one focused interaction\n(e.g. one round of clarification, one tool invocation cycle).",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "messages": {
          "items": {
            "$ref": "#/$defs/Message"
          },
          "title": "Messages",
          "type": "array"
        }
      },
      "required": [
        "id",
        "messages"
      ],
      "title": "Episode",
      "type": "object"
    },
    "Message": {
      "description": "A single message within a conversation episode.",
      "properties": {
        "content": {
          "title": "Content",
          "type": "string"
        }
      },
      "required": [
        "content"
      ],
      "title": "Message",
      "type": "object"
    }
  },
  "description": "A unit of work assigned to a team member, tracked through one or more episodes.\nStatus lifecycle example: \"pending\" \u2192 \"in_progress\" \u2192 \"completed\" | \"blocked\"",
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "assigned_to": {
      "title": "Assigned To",
      "type": "string"
    },
    "task_description": {
      "title": "Task Description",
      "type": "string"
    },
    "status": {
      "title": "Status",
      "type": "string"
    },
    "episodes": {
      "items": {
        "$ref": "#/$defs/Episode"
      },
      "title": "Episodes",
      "type": "array"
    }
  },
  "required": [
    "id",
    "assigned_to",
    "task_description",
    "status",
    "episodes"
  ],
  "title": "TaskWork",
  "type": "object",
  "version": "0.0.3"
}