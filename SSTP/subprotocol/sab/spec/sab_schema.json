{
  "$defs": {
    "DriftDetectionOutput": {
      "description": "Top-level Drift Detection output (formerly SAVOutput).\n\nPlaced in the L9 response message at the dotted path the caller\nspecified in ``header.attributes['drift']``. Empty\n``failure_modes`` list means no drift was detected.",
      "properties": {
        "failure_modes": {
          "description": "Detected process failure modes; empty list = no drift detected",
          "items": {
            "$ref": "#/$defs/FailureMode"
          },
          "title": "Failure Modes",
          "type": "array"
        }
      },
      "title": "DriftDetectionOutput",
      "type": "object"
    },
    "FailureMode": {
      "description": "A single detected process failure mode.",
      "properties": {
        "type": {
          "$ref": "#/$defs/ProcessFailureMode",
          "description": "Detected failure-mode category"
        },
        "score": {
          "description": "Confidence score in [0,1]; lower = stronger evidence of drift",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "description": {
          "description": "Static taxonomy description for ``type``",
          "title": "Description",
          "type": "string"
        },
        "reasoning": {
          "description": "Engine's per-instance justification for flagging this mode",
          "title": "Reasoning",
          "type": "string"
        }
      },
      "required": [
        "type",
        "score",
        "severity",
        "description",
        "reasoning"
      ],
      "title": "FailureMode",
      "type": "object"
    },
    "NegotiateCommitSemanticContext": {
      "description": "Semantic context for ``kind='commit'`` messages that finalize a negotiation.",
      "properties": {
        "schema_version": {
          "default": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "encoding": {
          "default": "json",
          "enum": [
            "json",
            "structured_text",
            "hybrid"
          ],
          "title": "Encoding",
          "type": "string"
        },
        "session_id": {
          "title": "Session Id",
          "type": "string"
        },
        "drift_detection": {
          "anyOf": [
            {
              "$ref": "#/$defs/DriftDetectionOutput"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional drift detection output associated with this context."
        },
        "outcome": {
          "description": "High-level outcome: 'agreement' \u2014 consensus reached; 'disagreement' \u2014 step budget exhausted; 'broken' \u2014 a participant dropped out or returned an invalid offer; 'error' \u2014 pipeline exception.",
          "title": "Outcome",
          "type": "string"
        },
        "error_message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Populated only when outcome='error'.",
          "title": "Error Message"
        },
        "content_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Original natural-language mission description passed to /initiate.",
          "title": "Content Text"
        },
        "agents_negotiating": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Agent IDs that participated in this negotiation.",
          "title": "Agents Negotiating"
        },
        "issues": {
          "description": "Ordered list of negotiable issue identifiers for this session.",
          "items": {
            "type": "string"
          },
          "title": "Issues",
          "type": "array"
        },
        "options_per_issue": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "description": "Candidate options per issue: {issue_id: [option, ...]}.",
          "title": "Options Per Issue",
          "type": "object"
        },
        "final_agreement": {
          "anyOf": [
            {
              "items": {
                "additionalProperties": true,
                "type": "object"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Agreed option per issue: {'issue_id': str, 'chosen_option': str}. None when the negotiation ended without agreement.",
          "title": "Final Agreement"
        }
      },
      "required": [
        "session_id",
        "outcome"
      ],
      "title": "NegotiateCommitSemanticContext",
      "type": "object"
    },
    "NegotiateSemanticContext": {
      "description": "SAO-specific semantic context for ``kind='negotiate'`` messages.\n\nCarries a full NegMAS SAO snapshot so receivers have the mechanism state,\nthe latest response, and (optionally) the NMI configuration in one place.",
      "properties": {
        "schema_version": {
          "default": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "encoding": {
          "default": "json",
          "enum": [
            "json",
            "structured_text",
            "hybrid"
          ],
          "title": "Encoding",
          "type": "string"
        },
        "session_id": {
          "title": "Session Id",
          "type": "string"
        },
        "issues": {
          "description": "Ordered list of negotiable issue identifiers for this session.",
          "items": {
            "type": "string"
          },
          "title": "Issues",
          "type": "array"
        },
        "options_per_issue": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "description": "Candidate options per issue: {issue_id: [option, ...]}.",
          "title": "Options Per Issue",
          "type": "object"
        },
        "options_memory_blob": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Fabric-memory cache (JSON string) used to warm-start options generation; null for LLM-only or when no memory hit occurred.",
          "title": "Options Memory Blob"
        },
        "sao_state": {
          "anyOf": [
            {
              "$ref": "#/$defs/SAOState"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "sao_response": {
          "anyOf": [
            {
              "$ref": "#/$defs/SAOResponse"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "nmi": {
          "anyOf": [
            {
              "$ref": "#/$defs/SAONMI"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "drift_detection": {
          "anyOf": [
            {
              "$ref": "#/$defs/DriftDetectionOutput"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional drift detection output associated with this context."
        },
        "offer_validation_failure": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Set when the previous counter_offer was rejected for unrecognised issue keys/option values (validation failure, not a strategic reject). Shape: {rejected_agent_id, round, problems, hint}.",
          "title": "Offer Validation Failure"
        }
      },
      "required": [
        "session_id"
      ],
      "title": "NegotiateSemanticContext",
      "type": "object"
    },
    "ProcessFailureMode": {
      "description": "PM-* \u2014 process-level failure modes detected from the interaction history.\n\nPM_0 (Unclassified) is emitted when the issue does not cleanly fit\none of PM_1 to PM_7.",
      "enum": [
        "Unclassified",
        "Persistent Divergence",
        "Dominant Narrative",
        "Repetition",
        "Reasoning Breakdown",
        "Task Deviation",
        "Constraint Violation",
        "Ambiguity"
      ],
      "title": "ProcessFailureMode",
      "type": "string"
    },
    "ResponseType": {
      "description": "Possible responses to offers during a NegMAS SAO negotiation round. Mirrors negmas.gb.common.ResponseType.",
      "enum": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "title": "ResponseType",
      "type": "integer",
      "x-enum-varnames": [
        "ACCEPT_OFFER",
        "REJECT_OFFER",
        "END_NEGOTIATION",
        "NO_RESPONSE",
        "WAIT",
        "LEAVE"
      ]
    },
    "SABCommitPayloadData": {
      "description": "``payload.data`` when the wrapped SSTP message is kind=commit.",
      "properties": {
        "message_id": {
          "title": "Message Id",
          "type": "string"
        },
        "version": {
          "default": "0",
          "description": "SSTP protocol version.",
          "title": "Version",
          "type": "string"
        },
        "dt_created": {
          "description": "ISO 8601 creation timestamp.",
          "title": "Dt Created",
          "type": "string"
        },
        "origin": {
          "$ref": "#/$defs/SABOrigin"
        },
        "payload_hash": {
          "description": "SHA-256 hex digest of the original payload.",
          "title": "Payload Hash",
          "type": "string"
        },
        "semantic_context": {
          "$ref": "#/$defs/NegotiateCommitSemanticContext"
        }
      },
      "required": [
        "message_id",
        "dt_created",
        "origin",
        "payload_hash",
        "semantic_context"
      ],
      "title": "SABCommitPayloadData",
      "type": "object"
    },
    "SABIntentPayloadData": {
      "description": "``payload.data`` when the wrapped SSTP message is kind=intent.",
      "properties": {
        "message_id": {
          "title": "Message Id",
          "type": "string"
        },
        "version": {
          "default": "0",
          "description": "SSTP protocol version.",
          "title": "Version",
          "type": "string"
        },
        "dt_created": {
          "description": "ISO 8601 creation timestamp.",
          "title": "Dt Created",
          "type": "string"
        },
        "origin": {
          "$ref": "#/$defs/SABOrigin"
        },
        "payload_hash": {
          "description": "SHA-256 hex digest of the original payload.",
          "title": "Payload Hash",
          "type": "string"
        },
        "semantic_context": {
          "$ref": "#/$defs/SemanticContext"
        }
      },
      "required": [
        "message_id",
        "dt_created",
        "origin",
        "payload_hash",
        "semantic_context"
      ],
      "title": "SABIntentPayloadData",
      "type": "object"
    },
    "SABNegotiatePayloadData": {
      "description": "``payload.data`` when the wrapped SSTP message is kind=negotiate.",
      "properties": {
        "message_id": {
          "title": "Message Id",
          "type": "string"
        },
        "version": {
          "default": "0",
          "description": "SSTP protocol version.",
          "title": "Version",
          "type": "string"
        },
        "dt_created": {
          "description": "ISO 8601 creation timestamp.",
          "title": "Dt Created",
          "type": "string"
        },
        "origin": {
          "$ref": "#/$defs/SABOrigin"
        },
        "payload_hash": {
          "description": "SHA-256 hex digest of the original payload.",
          "title": "Payload Hash",
          "type": "string"
        },
        "semantic_context": {
          "$ref": "#/$defs/NegotiateSemanticContext"
        },
        "round_messages": {
          "description": "Pending per-round SAB L9 envelopes the recipient must dispatch to the participant agents this round. Each item is itself a full SAB contingency/negotiation message (header + payload). Named distinctly from the header's own ``message`` field. Populated on an ongoing negotiation response; empty when there is nothing to dispatch.",
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "title": "Round Messages",
          "type": "array"
        }
      },
      "required": [
        "message_id",
        "dt_created",
        "origin",
        "payload_hash",
        "semantic_context"
      ],
      "title": "SABNegotiatePayloadData",
      "type": "object"
    },
    "SABOrigin": {
      "description": "Who produced this message (tenant_id is not carried at the L9 layer).",
      "properties": {
        "actor_id": {
          "title": "Actor Id",
          "type": "string"
        },
        "attestation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Attestation"
        }
      },
      "required": [
        "actor_id"
      ],
      "title": "SABOrigin",
      "type": "object"
    },
    "SAONMI": {
      "description": "NegotiatorMechanismInterface configuration snapshot for SAO.\n\nOmits the internal ``_mechanism`` back-reference and the ``time_limit`` /\n``n_steps`` computed fields (derived at runtime). All base fields have\ndefaults so this can be built from a plain dict / JSON snapshot.",
      "properties": {
        "id": {
          "default": "",
          "title": "Id",
          "type": "string"
        },
        "n_outcomes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "number"
            }
          ],
          "default": 0,
          "title": "N Outcomes"
        },
        "shared_time_limit": {
          "default": 1.7976931348623157e+308,
          "title": "Shared Time Limit",
          "type": "number"
        },
        "shared_n_steps": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Shared N Steps"
        },
        "private_time_limit": {
          "default": 1.7976931348623157e+308,
          "title": "Private Time Limit",
          "type": "number"
        },
        "private_n_steps": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Private N Steps"
        },
        "pend": {
          "default": 0.0,
          "title": "Pend",
          "type": "number"
        },
        "pend_per_second": {
          "default": 0.0,
          "title": "Pend Per Second",
          "type": "number"
        },
        "step_time_limit": {
          "default": 1.7976931348623157e+308,
          "title": "Step Time Limit",
          "type": "number"
        },
        "negotiator_time_limit": {
          "default": 1.7976931348623157e+308,
          "title": "Negotiator Time Limit",
          "type": "number"
        },
        "dynamic_entry": {
          "default": false,
          "title": "Dynamic Entry",
          "type": "boolean"
        },
        "max_n_negotiators": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max N Negotiators"
        },
        "annotation": {
          "additionalProperties": true,
          "title": "Annotation",
          "type": "object"
        },
        "end_on_no_response": {
          "default": true,
          "title": "End On No Response",
          "type": "boolean"
        },
        "one_offer_per_step": {
          "default": false,
          "title": "One Offer Per Step",
          "type": "boolean"
        },
        "offering_is_accepting": {
          "default": true,
          "title": "Offering Is Accepting",
          "type": "boolean"
        },
        "allow_none_with_data": {
          "default": true,
          "title": "Allow None With Data",
          "type": "boolean"
        },
        "allow_negotiators_to_leave": {
          "default": true,
          "title": "Allow Negotiators To Leave",
          "type": "boolean"
        }
      },
      "title": "SAONMI",
      "type": "object"
    },
    "SAOResponse": {
      "description": "A single negotiator response in one SAO round.",
      "properties": {
        "response": {
          "$ref": "#/$defs/ResponseType",
          "default": 3
        },
        "outcome": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "items": {},
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Outcome"
        },
        "data": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Data"
        }
      },
      "title": "SAOResponse",
      "type": "object"
    },
    "SAOState": {
      "description": "Full mechanism state for the Stacked Alternating Offers (SAO) protocol.",
      "properties": {
        "running": {
          "default": false,
          "title": "Running",
          "type": "boolean"
        },
        "waiting": {
          "default": false,
          "title": "Waiting",
          "type": "boolean"
        },
        "started": {
          "default": false,
          "title": "Started",
          "type": "boolean"
        },
        "step": {
          "default": 0,
          "title": "Step",
          "type": "integer"
        },
        "time": {
          "default": 0.0,
          "title": "Time",
          "type": "number"
        },
        "relative_time": {
          "default": 0.0,
          "title": "Relative Time",
          "type": "number"
        },
        "broken": {
          "default": false,
          "title": "Broken",
          "type": "boolean"
        },
        "timedout": {
          "default": false,
          "title": "Timedout",
          "type": "boolean"
        },
        "agreement": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "items": {},
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agreement"
        },
        "results": {
          "default": null,
          "title": "Results"
        },
        "n_negotiators": {
          "default": 0,
          "title": "N Negotiators",
          "type": "integer"
        },
        "has_error": {
          "default": false,
          "title": "Has Error",
          "type": "boolean"
        },
        "error_details": {
          "default": "",
          "title": "Error Details",
          "type": "string"
        },
        "erred_negotiator": {
          "default": "",
          "title": "Erred Negotiator",
          "type": "string"
        },
        "erred_agent": {
          "default": "",
          "title": "Erred Agent",
          "type": "string"
        },
        "threads": {
          "additionalProperties": {
            "$ref": "#/$defs/ThreadState"
          },
          "title": "Threads",
          "type": "object"
        },
        "last_thread": {
          "default": "",
          "title": "Last Thread",
          "type": "string"
        },
        "left_negotiators": {
          "items": {
            "type": "string"
          },
          "title": "Left Negotiators",
          "type": "array"
        },
        "current_offer": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "items": {},
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Current Offer"
        },
        "current_proposer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Current Proposer"
        },
        "current_proposer_agent": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Current Proposer Agent"
        },
        "n_acceptances": {
          "default": 0,
          "title": "N Acceptances",
          "type": "integer"
        },
        "new_offers": {
          "items": {
            "maxItems": 2,
            "minItems": 2,
            "prefixItems": [
              {
                "type": "string"
              },
              {
                "anyOf": [
                  {
                    "additionalProperties": true,
                    "type": "object"
                  },
                  {
                    "items": {},
                    "type": "array"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            ],
            "type": "array"
          },
          "title": "New Offers",
          "type": "array"
        },
        "new_offerer_agents": {
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "New Offerer Agents",
          "type": "array"
        },
        "last_negotiator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Negotiator"
        },
        "current_data": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Current Data"
        },
        "new_data": {
          "items": {
            "maxItems": 2,
            "minItems": 2,
            "prefixItems": [
              {
                "type": "string"
              },
              {
                "anyOf": [
                  {
                    "additionalProperties": true,
                    "type": "object"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            ],
            "type": "array"
          },
          "title": "New Data",
          "type": "array"
        }
      },
      "title": "SAOState",
      "type": "object"
    },
    "SemanticContext": {
      "description": "Schema/encoding metadata for a plain (intent) payload.",
      "properties": {
        "schema_version": {
          "default": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "encoding": {
          "default": "json",
          "enum": [
            "json",
            "structured_text",
            "hybrid"
          ],
          "title": "Encoding",
          "type": "string"
        },
        "drift_detection": {
          "anyOf": [
            {
              "$ref": "#/$defs/DriftDetectionOutput"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional drift detection output associated with this context."
        }
      },
      "title": "SemanticContext",
      "type": "object"
    },
    "Severity": {
      "description": "Severity verdict for one failure mode.\n\n``type`` is the bucket the engine assigned. ``high`` and ``medium``\nare the score thresholds the engine used: score \u2264 high \u2192 HIGH,\nscore \u2264 medium \u2192 MEDIUM, otherwise LOW. Thresholds are returned so\ncallers can re-bucket under their own policy.",
      "properties": {
        "type": {
          "$ref": "#/$defs/SeverityLevel",
          "description": "Assigned severity bucket"
        },
        "high": {
          "description": "Score \u2264 this \u2192 HIGH",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "High",
          "type": "number"
        },
        "medium": {
          "description": "Score \u2264 this \u2192 MEDIUM",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Medium",
          "type": "number"
        }
      },
      "required": [
        "type",
        "high",
        "medium"
      ],
      "title": "Severity",
      "type": "object"
    },
    "SeverityLevel": {
      "description": "Discrete severity bucket for a detected failure mode.",
