# Required — LiteLLM proxy endpoint and credentials
LITELLM_API_KEY=your-api-key-here
LITELLM_BASE_URL=https://litellm.your-instance.example.com
LITELLM_HAIKU_MODEL=your-haiku-model-name

# Alternative — Azure OpenAI direct (used if LITELLM_* vars are absent)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_KEY=your-azure-key
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
