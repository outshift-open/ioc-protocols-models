{
  "$defs": {
    "Actor": {
      "description": "A participant in a protocol exchange \u2014 can be a human, an AI agent, or a system.\nMultiple actors are listed in L9Header.actors to identify sender(s) and receiver(s).",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "role": {
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "id",
        "type",
        "name",
        "role"
      ],
      "title": "Actor",
      "type": "object"
    },
    "Epistemic": {
      "description": "Agent epistemic (belief/knowledge) state at the time the message was sent.\nCurrently a placeholder \u2014 fields will be added as the model is defined.",
      "properties": {},
      "title": "Epistemic",
      "type": "object"
    },
    "Group": {
      "description": "Logical grouping of actors \u2014 e.g. a team, session, or conversation thread.\nUsed in L9Header to scope the message to a shared context.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "title": "Group",
      "type": "object"
    },
    "L9Header": {
      "description": "Routing and metadata envelope for every L9 message.\nThe CFN layer reads the header \u2014 especially `kind` and `sub_kind` \u2014\nto decide which Cognitive Engine (CE) should handle the message.",
      "properties": {
        "protocol": {
          "title": "Protocol",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "sub_kind": {
          "title": "Sub Kind",
          "type": "string"
        },
        "group": {
          "$ref": "#/$defs/Group"
        },
        "actors": {
          "items": {
            "$ref": "#/$defs/Actor"
          },
          "title": "Actors",
          "type": "array"
        },
        "semantic": {
          "$ref": "#/$defs/SemanticContext"
        },
        "policy": {
          "anyOf": [
            {
              "$ref": "#/$defs/PolicyLabel"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "provenance": {
          "anyOf": [
            {
              "$ref": "#/$defs/Provenance"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "epistemic": {
          "anyOf": [
            {
              "$ref": "#/$defs/Epistemic"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "protocol",
        "version",
        "kind",
        "sub_kind",
        "group",
        "actors",
        "semantic"
      ],
      "title": "L9Header",
      "type": "object"
    },
    "L9Payload": {
      "description": "The actual content being carried by an L9 message.\nThe `type` field describes the payload format; `data` holds the content.",
      "properties": {
        "type": {
          "title": "Type",
          "type": "string"
        },
        "data": {
          "title": "Data",
          "type": "object"
        }
      },
      "required": [
        "type",
        "data"
      ],
      "title": "L9Payload",
      "type": "object"
    },
    "PolicyLabel": {
      "description": "Data governance and access-control labels applied to the message.\n## TODO Nandu, Peter please review",
      "properties": {
        "sensitivity": {
          "title": "Sensitivity",
          "type": "string"
        },
        "propagation": {
          "title": "Propagation",
          "type": "string"
        },
        "retention_policy": {
          "title": "Retention Policy",
          "type": "string"
        }
      },
      "required": [
        "sensitivity",
        "propagation",
        "retention_policy"
      ],
      "title": "PolicyLabel",
      "type": "object"
    },
    "Provenance": {
      "description": "Tracks the origin and lineage of a message \u2014 who created it, from what source,\nand through which transformations. Fields TBD.",
      "properties": {},
      "title": "Provenance",
      "type": "object"
    },
    "SemanticContext": {
      "description": "Describes the semantic/ontological framework needed to correctly interpret the payload.\nThe CFN routing layer uses this to select appropriate cognitive engines (CEs).",
      "properties": {
        "schema_id": {
          "title": "Schema Id",
          "type": "string"
        },
        "ontology_ref": {
          "title": "Ontology Ref",
          "type": "string"
        },
        "cognition_protocol": {
          "title": "Cognition Protocol",
          "type": "string"
        }
      },
      "required": [
        "schema_id",
        "ontology_ref",
        "cognition_protocol"
      ],
      "title": "SemanticContext",
      "type": "object"
    }
  },
  "description": "A complete L9 message: header (routing/metadata) + payload (content).\nThis is the top-level structure passed between agents and through the CFN.",
  "properties": {
    "header": {
      "$ref": "#/$defs/L9Header"
    },
    "payload": {
      "$ref": "#/$defs/L9Payload"
    }
  },
  "required": [
    "header",
    "payload"
  ],
  "title": "L9",
  "type": "object"
}